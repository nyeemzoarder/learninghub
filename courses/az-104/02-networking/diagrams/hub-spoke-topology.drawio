<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Hub-Spoke Topology" id="hub-spoke">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Hub VNet -->
        <mxCell id="hub" value="vnet-hub (10.0.0.0/16)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="260" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gatewaySubnet" value="GatewaySubnet&#10;(VPN Gateway)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="fwSubnet" value="AzureFirewallSubnet / NVA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="340" y="150" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- On-prem -->
        <mxCell id="onprem" value="On-premises network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="320" y="280" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eVpn" value="S2S VPN" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=open;" edge="1" parent="1" source="onprem" target="gatewaySubnet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Spoke 1: prod -->
        <mxCell id="prod" value="vnet-prod (10.1.0.0/16)&#10;Production workloads&#10;NSG restricts inbound to&#10;App Gateway subnet only" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Spoke 2: dev -->
        <mxCell id="dev" value="vnet-dev (10.2.0.0/16)&#10;Dev/test workloads" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="640" y="40" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Peering -->
        <mxCell id="eProdHub" value="Peering&#10;(use remote gateway)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=open;" edge="1" parent="1" source="prod" target="hub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eDevHub" value="Peering&#10;(use remote gateway)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=open;" edge="1" parent="1" source="dev" target="hub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Non-transitive note -->
        <mxCell id="note" value="vnet-prod and vnet-dev are NOT peered directly.&#10;Spoke-to-spoke traffic (if needed) routes through&#10;the hub's firewall/NVA via UDRs — peering is&#10;non-transitive." style="text;html=1;align=center;verticalAlign=middle;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="280" y="380" width="340" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
